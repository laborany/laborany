# LaborAny 环境变量配置
# 此文件由应用自动复制到用户配置目录

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                       Anthropic API 配置                                  │
# └──────────────────────────────────────────────────────────────────────────┘

# Anthropic API 密钥（必填）
ANTHROPIC_API_KEY=your-api-key-here

# Anthropic API 基础 URL（可选，用于代理服务）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Anthropic 模型名称（可选）
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                       服务配置                                            │
# └──────────────────────────────────────────────────────────────────────────┘

# API 服务端口（src-api）
PORT=3620

# Agent Service 端口
AGENT_PORT=3002

# JWT 签名密钥（用于用户认证）
LABORANY_SECRET_KEY=your-secret-key-change-in-production

# src-api base URL for cron execution bridge
SRC_API_BASE_URL=http://127.0.0.1:3620/api

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                       微信 Bot 配置                                       │
# └──────────────────────────────────────────────────────────────────────────┘

# 微信 ClawBot 启用开关
# WECHAT_ENABLED=true

# 微信 iLink / CDN 基础地址
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# WECHAT_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c

# 微信 Bot Token（可选）
# 推荐在设置页使用“扫码绑定”获取并保存本地凭据；仅在需要手工覆盖时填写
# WECHAT_BOT_TOKEN=your-wechat-bot-token

# 微信用户白名单（逗号分隔的 userId，留空表示允许所有用户）
# WECHAT_ALLOW_USERS=user1@im.wechat,user2@im.wechat

# 微信 Bot 是否强制白名单（为 true 时，白名单为空则拒绝启动）
# WECHAT_REQUIRE_ALLOWLIST=false

# 微信 Bot 显示名称
# WECHAT_BOT_NAME=LaborAny

# 微信默认技能 ID
# WECHAT_DEFAULT_SKILL=__generic__

# 长轮询超时与文本分段上限
# WECHAT_POLL_TIMEOUT_MS=35000
# WECHAT_TEXT_CHUNK_LIMIT=1000

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                       飞书 Bot 配置                                       │
# └──────────────────────────────────────────────────────────────────────────┘

# Feishu Bot
# FEISHU_ENABLED=true
# FEISHU_APP_ID=cli_xxxxxxxxxx
# FEISHU_APP_SECRET=your-feishu-app-secret
# FEISHU_DOMAIN=feishu
# FEISHU_ALLOW_USERS=ou_xxx,ou_yyy
# FEISHU_REQUIRE_ALLOWLIST=false
# FEISHU_BOT_NAME=LaborAny
# FEISHU_DEFAULT_SKILL=__generic__

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                       QQ Bot 配置                                         │
# └──────────────────────────────────────────────────────────────────────────┘

# QQ Bot 启用开关
# QQ_ENABLED=true

# QQ Bot 应用凭证（从 QQ 开放平台获取）
# QQ_APP_ID=your-qq-app-id
# QQ_APP_SECRET=your-qq-app-secret   # 推荐，仅填这一项也可用
# QQ_BOT_TOKEN=your-qq-bot-token     # 可选（与 QQ_APP_SECRET 二选一）

# QQ Bot 沙箱模式（测试环境使用）
# QQ_SANDBOX=false

# QQ Bot 用户白名单（逗号分隔的用户 ID，留空表示允许所有用户）
# QQ_ALLOW_USERS=user_id_1,user_id_2

# QQ Bot 是否强制白名单（为 true 时，白名单为空则拒绝所有消息）
# QQ_REQUIRE_ALLOWLIST=false

# QQ Bot 显示名称
# QQ_BOT_NAME=LaborAny

# QQ Bot 默认技能 ID
# QQ_DEFAULT_SKILL=__generic__
