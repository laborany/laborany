# ╔══════════════════════════════════════════════════════════════════════════╗
# ║                         LaborAny .gitignore                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           环境变量                                        │
# └──────────────────────────────────────────────────────────────────────────┘
.env
.env.local
.env.*.local

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           依赖目录                                        │
# └──────────────────────────────────────────────────────────────────────────┘
node_modules/
# Exception: LaborAny 设计大师 skill 需要预装依赖随包发布（Chromium 不下载）
!skills/laborany-design/node_modules/
!skills/laborany-design/node_modules/**

# ffmpeg 静态二进制（构建前 node scripts/fetch-ffmpeg-bundles.mjs 拉取，不入 git）
ffmpeg-bundle-*/ffmpeg
ffmpeg-bundle-*/ffmpeg.exe
__pycache__/
*.pyc
.venv/
venv/
env/

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           构建产物                                        │
# └──────────────────────────────────────────────────────────────────────────┘
dist/
build/
*.egg-info/
cli-bundle/
cli-bundle-*/
uv-bundle/
uv-bundle-*/
git-bash/
*.tsbuildinfo

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           任务产出文件                                     │
# └──────────────────────────────────────────────────────────────────────────┘
tasks/

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           数据库                                          │
# └──────────────────────────────────────────────────────────────────────────┘
*.db
*.sqlite
*.sqlite3

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           IDE / 编辑器                                    │
# └──────────────────────────────────────────────────────────────────────────┘
.idea/
.vscode/
.claude/settings.local.json
*.swp
*.swo
*~

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           系统文件                                        │
# └──────────────────────────────────────────────────────────────────────────┘
.DS_Store
Thumbs.db

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           日志                                            │
# └──────────────────────────────────────────────────────────────────────────┘
*.log
logs/

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           Tauri / Rust                                    │
# └──────────────────────────────────────────────────────────────────────────┘
src-tauri/target/
Cargo.lock

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           Electron 构建产物                               │
# └──────────────────────────────────────────────────────────────────────────┘
release/
electron/dist/

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           临时下载的工具                                   │
# └──────────────────────────────────────────────────────────────────────────┘
rustup-init.exe
vs_buildtools.exe

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           数据目录                                        │
# └──────────────────────────────────────────────────────────────────────────┘
data/

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           临时文件 / 调试产物                              │
# └──────────────────────────────────────────────────────────────────────────┘
tmp-debug/
nul
*.zip
*.nsi
*.exe
.workflow/

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           个人工作空间文件                                 │
# └──────────────────────────────────────────────────────────────────────────┘
CLAUDE.md

# ┌──────────────────────────────────────────────────────────────────────────┐
# │                           测试文件                                        │
# └──────────────────────────────────────────────────────────────────────────┘
**/test-*.mjs
**/test-*.js
offline-cache/
